# JWT Configuration
JWT_SECRET=your_32_byte_hex_secret_here
JWT_EXPIRE_HOURS=8

# Database/Storage Encryption Key
# Generate one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000,http://localhost:5174,http://127.0.0.1:5174

# Gemini API Configuration
# NOTE: GEMINI_API_KEY in .env is NOT used as fallback in production. Users (teachers) must configure
# their own API Key in settings. This environment variable is only used to seed test accounts in E2E tests (test_all.py).
GEMINI_API_KEY=your_gemini_api_key_from_google_ai_studio
GEMINI_MODEL=gemini-3.5-flash

# Default AI Provider Configuration (Groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

