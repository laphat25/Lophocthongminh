    "graded_by": "31b0977d-b73a-4a15-9811-dd30021f6b7e",
    "criteria_scores": [
      {
        "criteria_id": "76742cde-385c-4d01-91bf-33a2a987e3e4",
        "criteria_name": "MỤC TIÊU BÀI HỌC (Kiến thức, Kỹ năng, Thái độ/NL)",
        "ai_suggested_score": 2.0,
        "ai_suggested_level": "Trình bày đầy đủ cả 3 mặt (KT-KN-TĐ). Dùng động từ hành động đo lường được. Mục tiêu cụ thể, phù hợp trình độ HS lớp 5. Có mục tiêu về NL và PC theo CT 2018 (1.8 – 2.0 điểm)",
        "final_score": 2.0,
        "max_score": 2.0,
        "weight": 20.0,
        "teacher_comment": "",
        "highlighted_text": [
          "MỤC TIÊU",
          "Kiến thức:",
          "Kỹ năng:"
        ]
      },
      {
        "criteria_id": "c4cb5afe-f6a6-4d3e-bd20-e93c90afdca1",
        "criteria_name": "CHUẨN BỊ DẠY - HỌC (Đồ dùng, phương tiện)",
        "ai_suggested_score": 0.5,
        "ai_suggested_level": "Liệt kê đầy đủ, chi tiết đồ dùng GV và HS. Đồ dùng sáng tạo, hỗ trợ tốt mục tiêu. Có phương tiện kỹ thuật phù hợp (0.45 – 0.5 điểm)",
        "final_score": 0.5,
        "max_score": 0.5,
        "weight": 5.0,
        "teacher_comment": "",
        "highlighted_text": [
          "SGK: Toán 5 - Cánh Diều",
          "- Học sinh hứng thú với môn học, cẩn thận khi tính toán",
          "CHUẨN BỊ"
        ]
      },
      {
        "criteria_id": "0f8e7db8-fe4a-4839-a2db-65b125cb3830",
        "criteria_name": "TIẾN TRÌNH DẠY HỌC (Số lượng và chất lượng HĐ)",
        "ai_suggested_score": 2.0,
        "ai_suggested_level": "≥ 4 hoạt động rõ ràng theo chu trình. Mỗi HĐ đủ: mục tiêu, nội dung, PP, TG. Phân bổ thời gian hợp lý, logic. Có chuyển tiếp giữa các HĐ tự nhiên (1.8 – 2.0 điểm)",
        "final_score": 2.0,
        "max_score": 2.0,
        "weight": 20.0,
        "teacher_comment": "",
        "highlighted_text": [
          "Thời gian: 45 phút",
          "TIẾN TRÌNH DẠY HỌC"
        ]
      },
      {
        "criteria_id": "01de7949-4e34-4e97-bc8a-c690071874d0",
        "criteria_name": "PHƯƠNG PHÁP DẠY HỌC TÍCH CỰC (Loại PP và mức độ phù hợp)",
        "ai_suggested_score": 1.5,
        "ai_suggested_level": "Sử dụng ≥ 2 PPDH tích cực (TLN, dự án, khám phá, PBL…). Giải thích rõ lý do chọn PP. PP phù hợp với mục tiêu và đối tượng HS. Kỹ thuật DH cụ thể (Think-Pair-Share, KWL…) (1.35 – 1.5 điểm)",
        "final_score": 1.5,
        "max_score": 1.5,
        "weight": 15.0,
        "teacher_comment": "",
        "highlighted_text": []
      },
      {
        "criteria_id": "2a926d0b-0f1a-4579-87a3-435efd323d95",
        "criteria_name": "SỬ DỤNG CÂU HỎI (Chất lượng câu hỏi trong HĐ)",
        "ai_suggested_score": 0.4,
        "ai_suggested_level": "Hầu hết là câu hỏi đóng 'có/không'. Không có câu hỏi kích thích tư duy (< 0.5 điểm)",
        "final_score": 0.4,
        "max_score": 1.0,
        "weight": 10.0,
        "teacher_comment": "",
        "highlighted_text": []
      },
      {
        "criteria_id": "055e9fea-3918-41d4-914d-f7eb6382c384",
        "criteria_name": "KẾ HOẠCH ĐÁNH GIÁ HS (Đánh giá QT và KQ)",
        "ai_suggested_score": 1.5,
        "ai_suggested_level": "Đánh giá quá trình + kết quả đầy đủ. Đa dạng hình thức: vấn đáp, phiếu học tập, sản phẩm, tự đánh giá. Có tiêu chí đánh giá cụ thể. Phù hợp với mục tiêu đề ra (1.35 – 1.5 điểm)",
        "final_score": 1.5,
        "max_score": 1.5,
        "weight": 15.0,
        "teacher_comment": "",
        "highlighted_text": []
      },
      {
        "criteria_id": "10c03c4e-8715-4c01-8473-1d394574ccb2",
        "criteria_name": "TÌNH HUỐNG SƯ PHẠM (Dự kiến và xử lý)",
        "ai_suggested_score": 0.5,
        "ai_suggested_level": "≥ 2 tình huống dự kiến. Tình huống thực tế, có khả năng xảy ra. Cách xử lý sư phạm, phù hợp tâm lý HS (0.45 – 0.5 điểm)",
        "final_score": 0.5,
        "max_score": 0.5,
        "weight": 5.0,
        "teacher_comment": "",
        "highlighted_text": [
          "TRƯỜNG ĐẠI HỌC SƯ PHẠM TP"
        ]
      },
      {
        "criteria_id": "bd8b5aeb-6f30-412e-92d0-3faf0f4de8ee",
        "criteria_name": "TRÌNH BÀY VÀ TÀI LIỆU (Form + TLTK)",
        "ai_suggested_score": 1.0,
        "ai_suggested_level": "Đúng quy định định dạng. Trang bìa đầy đủ, chuyên nghiệp. ≥ 3 TLTK đúng chuẩn APA hoặc Việt Nam. Không lỗi chính tả, ngữ pháp (0.9 – 1.0 điểm)",
        "final_score": 1.0,
        "max_score": 1.0,
        "weight": 10.0,
        "teacher_comment": "",
        "highlighted_text": [
          "TÀI LIỆU THAM KHẢO"
        ]
      }
    ],
