        "final_score": 1.0,
        "max_score": 2.0,
        "weight": 20.0,
        "teacher_comment": "",
        "highlighted_text": [
          "Mục tiêu:"
        ]
      },
      {
        "criteria_id": "c4cb5afe-f6a6-4d3e-bd20-e93c90afdca1",
        "criteria_name": "CHUẨN BỊ DẠY - HỌC (Đồ dùng, phương tiện)",
        "ai_suggested_score": 0.5,
        "ai_suggested_level": "Liệt kê đầy đủ, chi tiết đồ dùng GV và HS. Đồ dùng sáng tạo, hỗ trợ tốt mục tiêu. Có phương tiện kỹ thuật phù hợp (0.45 – 0.5 điểm)",
        "final_score": 0.5,
        "max_score": 0.5,
        "weight": 5.0,
        "teacher_comment": "",
        "highlighted_text": [
          "Giáo viên: Phạm Minh Đức",
          "Học sinh biết hình thang",
          "Chuẩn bị:"
        ]
      },
      {
        "criteria_id": "0f8e7db8-fe4a-4839-a2db-65b125cb3830",
        "criteria_name": "TIẾN TRÌNH DẠY HỌC (Số lượng và chất lượng HĐ)",
        "ai_suggested_score": 1.0,
        "ai_suggested_level": "3 hoạt động, thiếu chi tiết 1 số HĐ. TG chưa hợp lý ở một số HĐ (1.0 – 1.3 điểm)",
        "final_score": 1.0,
        "max_score": 2.0,
        "weight": 20.0,
        "teacher_comment": "",
        "highlighted_text": []
      },
      {
        "criteria_id": "01de7949-4e34-4e97-bc8a-c690071874d0",
        "criteria_name": "PHƯƠNG PHÁP DẠY HỌC TÍCH CỰC (Loại PP và mức độ phù hợp)",
        "ai_suggested_score": 0.9,
        "ai_suggested_level": "1 PPDH tích cực + DH truyền thống. Chưa giải thích rõ (0.75 – 1.04 điểm)",
        "final_score": 0.9,
        "max_score": 1.5,
        "weight": 15.0,
        "teacher_comment": "",
        "highlighted_text": []
      },
      {
        "criteria_id": "2a926d0b-0f1a-4579-87a3-435efd323d95",
        "criteria_name": "SỬ DỤNG CÂU HỎI (Chất lượng câu hỏi trong HĐ)",
        "ai_suggested_score": 1.0,
        "ai_suggested_level": "Câu hỏi đa dạng: nhớ, hiểu, vận dụng, phân tích (Bloom). Câu hỏi mở, kích thích tư duy. Phân bố đều trong các HĐ (0.9 – 1.0 điểm)",
        "final_score": 1.0,
        "max_score": 1.0,
        "weight": 10.0,
        "teacher_comment": "",
        "highlighted_text": []
      },
      {
        "criteria_id": "055e9fea-3918-41d4-914d-f7eb6382c384",
        "criteria_name": "KẾ HOẠCH ĐÁNH GIÁ HS (Đánh giá QT và KQ)",
        "ai_suggested_score": 1.5,
        "ai_suggested_level": "Đánh giá quá trình + kết quả đầy đủ. Đa dạng hình thức: vấn đáp, phiếu học tập, sản phẩm, tự đánh giá. Có tiêu chí đánh giá cụ thể. Phù hợp với mục tiêu đề ra (1.35 – 1.5 điểm)",
        "final_score": 1.5,
        "max_score": 1.5,
        "weight": 15.0,
        "teacher_comment": "",
        "highlighted_text": []
      },
      {
        "criteria_id": "10c03c4e-8715-4c01-8473-1d394574ccb2",
        "criteria_name": "TÌNH HUỐNG SƯ PHẠM (Dự kiến và xử lý)",
        "ai_suggested_score": 0.4,
        "ai_suggested_level": "2 tình huống, xử lý tương đối hợp lý (0.35 – 0.44 điểm)",
        "final_score": 0.4,
        "max_score": 0.5,
        "weight": 5.0,
        "teacher_comment": "",
        "highlighted_text": []
      },
      {
        "criteria_id": "bd8b5aeb-6f30-412e-92d0-3faf0f4de8ee",
        "criteria_name": "TRÌNH BÀY VÀ TÀI LIỆU (Form + TLTK)",
        "ai_suggested_score": 1.0,
        "ai_suggested_level": "Đúng quy định định dạng. Trang bìa đầy đủ, chuyên nghiệp. ≥ 3 TLTK đúng chuẩn APA hoặc Việt Nam. Không lỗi chính tả, ngữ pháp (0.9 – 1.0 điểm)",
