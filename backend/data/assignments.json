      {
        "criteria_id": "055e9fea-3918-41d4-914d-f7eb6382c384",
        "criteria_name": "KẾ HOẠCH ĐÁNH GIÁ HS (Đánh giá QT và KQ)",
        "max_score": 1.5,
        "weight": 15.0,
        "keywords": [
          "kế hoạch đánh giá",
          "đánh giá quá trình",
          "kết quả",
          "vấn đáp",
          "phiếu học tập",
          "sản phẩm",
          "tự đánh giá",
          "tiêu chí"
        ],
        "levels": [
          {
            "score": 1.5,
            "description": "Đánh giá quá trình + kết quả đầy đủ. Đa dạng hình thức: vấn đáp, phiếu học tập, sản phẩm, tự đánh giá. Có tiêu chí đánh giá cụ thể. Phù hợp với mục tiêu đề ra (1.35 – 1.5 điểm)"
          },
          {
            "score": 1.2,
            "description": "Có đánh giá QT và KQ. 2-3 hình thức đánh giá. Tiêu chí tương đối rõ (1.05 – 1.34 điểm)"
          },
          {
            "score": 0.9,
            "description": "Chỉ đánh giá kết quả. 1-2 hình thức. Tiêu chí chung chung (0.75 – 1.04 điểm)"
          },
          {
            "score": 0.5,
            "description": "Không có kế hoạch đánh giá. Hoặc chỉ ghi 'chấm bài' (< 0.75 điểm)"
          }
        ]
      },
      {
        "criteria_id": "10c03c4e-8715-4c01-8473-1d394574ccb2",
        "criteria_name": "TÌNH HUỐNG SƯ PHẠM (Dự kiến và xử lý)",
        "max_score": 0.5,
        "weight": 5.0,
        "keywords": [
          "tình huống",
          "sư phạm",
          "dự kiến",
          "xử lý",
          "thực tế",
          "tâm lý học sinh"
        ],
        "levels": [
          {
            "score": 0.5,
            "description": "≥ 2 tình huống dự kiến. Tình huống thực tế, có khả năng xảy ra. Cách xử lý sư phạm, phù hợp tâm lý HS (0.45 – 0.5 điểm)"
          },
          {
            "score": 0.4,
            "description": "2 tình huống, xử lý tương đối hợp lý (0.35 – 0.44 điểm)"
          },
          {
            "score": 0.3,
            "description": "1 tình huống, xử lý đơn giản (0.25 – 0.34 điểm)"
          },
          {
            "score": 0.15,
            "description": "Không có tình huống sư phạm (< 0.25 điểm)"
          }
        ]
      },
      {
        "criteria_id": "bd8b5aeb-6f30-412e-92d0-3faf0f4de8ee",
        "criteria_name": "TRÌNH BÀY VÀ TÀI LIỆU (Form + TLTK)",
        "max_score": 1.0,
        "weight": 10.0,
        "keywords": [
          "trình bày",
          "tài liệu",
          "định dạng",
          "trang bìa",
          "tài liệu tham khảo",
          "tltk",
          "apa",
          "chính tả",
          "ngữ pháp"
        ],
        "levels": [
          {
            "score": 1.0,
            "description": "Đúng quy định định dạng. Trang bìa đầy đủ, chuyên nghiệp. ≥ 3 TLTK đúng chuẩn APA hoặc Việt Nam. Không lỗi chính tả, ngữ pháp (0.9 – 1.0 điểm)"
          },
          {
            "score": 0.8,
            "description": "Đúng quy định cơ bản. ≥ 3 TLTK. Ít lỗi chính tả (0.7 – 0.89 điểm)"
          },
          {
            "score": 0.6,
            "description": "Một số lỗi định dạng. 2 TLTK hoặc chưa đúng chuẩn. Có lỗi chính tả (0.5 – 0.69 điểm)"
          },
          {
            "score": 0.4,
            "description": "Sai nhiều quy định định dạng. < 2 TLTK hoặc không có. Nhiều lỗi chính tả (< 0.5 điểm)"
          }
        ]
      }
    ],
