# ─────────────────────────────────────────
#  BACKEND – Python / FastAPI
# ─────────────────────────────────────────

# Virtual environment
backend/.venv/
backend/venv/
backend/env/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/
dist/
build/

# Environment variables (chứa secret key, API key)
backend/.env

# File uploads của sinh viên (dữ liệu runtime, không commit)
backend/uploads/

# Dữ liệu runtime (JSON store)
# Bỏ comment dòng dưới nếu không muốn commit data
# backend/data/


# ─────────────────────────────────────────
#  FRONTEND – Vite / React / TypeScript
# ─────────────────────────────────────────

# Dependencies
frontend/node_modules/

# Build output
frontend/dist/
frontend/build/

# Yarn PnP cache (chỉ commit .pnp.cjs nếu dùng Zero-Install)
# Bỏ comment nếu KHÔNG dùng Zero-Install:
# frontend/.pnp.cjs
# frontend/.pnp.loader.mjs
# frontend/.yarn/cache/
# frontend/.yarn/unplugged/

# Yarn install state (luôn bỏ)
frontend/.yarn/install-state.gz

# Vite / TS cache
frontend/.vite/
frontend/tsconfig.tsbuildinfo
frontend/node_modules/.tmp/

# Environment variables frontend
frontend/.env
frontend/.env.local
frontend/.env.*.local


# ─────────────────────────────────────────
#  CHUNG
# ─────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor / IDE
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage / test output
coverage/
.coverage
htmlcov/
.pytest_cache/
